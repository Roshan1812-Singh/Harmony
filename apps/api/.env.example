# Runtime
NODE_ENV=development
PORT=4000
API_GLOBAL_PREFIX=api/v1
LOG_LEVEL=debug

# Web origin (CORS + cookies)
WEB_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://harmony:harmony@localhost:5432/harmony?schema=public
SHADOW_DATABASE_URL=postgresql://harmony:harmony@localhost:5432/harmony_shadow?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Elasticsearch (optional; falls back to PG FTS if blank)
ELASTICSEARCH_NODE=http://localhost:9200

# JWT (RS256). In dev these are PEM strings; in prod load from secrets manager.
JWT_ACCESS_PRIVATE_KEY=
JWT_ACCESS_PUBLIC_KEY=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=harmony

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_RAW=harmony-raw
S3_BUCKET_STREAM=harmony-stream
S3_BUCKET_PUBLIC_ART=harmony-public-art
S3_FORCE_PATH_STYLE=true

# CloudFront (production)
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_PEM=

# Email (Mailhog in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Harmony <no-reply@harmony.local>"

# Rate limit
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Sentry
SENTRY_DSN=

# Admin bootstrap
SEED_ADMIN_EMAIL=admin@harmony.local
SEED_ADMIN_PASSWORD=Admin!234
