# ===========================================================================
# Harmony API — production environment template
# Copy these into your host's dashboard (Railway / Render / Fly secrets).
# ===========================================================================

NODE_ENV=production
# Most hosts inject PORT automatically; the app binds to it.
PORT=4000
API_GLOBAL_PREFIX=api/v1
LOG_LEVEL=info

# --- URLs / CORS -----------------------------------------------------------
# Your deployed frontend (used for OAuth redirects + default CORS).
WEB_ORIGIN=https://your-frontend.vercel.app
# Comma-separated browser origins allowed to call the API with credentials.
# Include the frontend; the Android app loads that same origin in its WebView.
CORS_ORIGINS=https://your-frontend.vercel.app

# --- Cross-site auth cookies (REQUIRED for a deployed app + Android app) ----
# The frontend and API live on different domains, so cookies must be
# SameSite=None and Secure (HTTPS only). Leave COOKIE_DOMAIN empty for a
# host-only cookie on the API domain.
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=

# --- Datastores (provided by your host's managed add-ons) ------------------
DATABASE_URL=postgresql://user:pass@host:5432/harmony?schema=public&sslmode=require
REDIS_URL=redis://default:pass@host:6379

# --- JWT -------------------------------------------------------------------
# Recommended for production: RS256 key pair (PEM, newlines as \n or multiline).
# If left empty, the app derives a deterministic HS256 dev secret (OK for hobby).
JWT_ACCESS_PRIVATE_KEY=
JWT_ACCESS_PUBLIC_KEY=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=harmony

# --- Optional services -----------------------------------------------------
# Search falls back to Postgres full-text if Elasticsearch is unset.
ELASTICSEARCH_NODE=
# Object storage for user uploads (imported catalog streams from external CDNs,
# so this is optional for playback-only usage).
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_RAW=
S3_BUCKET_STREAM=
S3_BUCKET_PUBLIC_ART=
# SMTP for email verification / password reset (optional).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@harmony.app
# OAuth (optional).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
